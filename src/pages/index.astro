<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Rocket Scene</title>
<style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 100%; min-height: 100vh; background: #0a0a1a; }
      #c {
        position: fixed; inset: 0;
        opacity: 0; transition: opacity 1.2s ease;
        background: #0a0a1a;
      }
      #c.ready { opacity: 1; }
      canvas { display: block; width: 100% !important; height: 100% !important; }

      #loader {
        position: fixed; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        background: #000;
        transition: opacity 0.8s ease;
        z-index: 10;
      }
      #loader.hidden { opacity: 0; pointer-events: none; }
      #loader-bar-wrap {
        width: 180px; height: 2px;
        background: rgba(255,255,255,0.12);
        border-radius: 2px; overflow: hidden;
        margin-top: 20px;
      }
      #loader-bar {
        height: 100%; width: 0%;
        background: linear-gradient(90deg, #4488ff, #aa44ff);
        border-radius: 2px;
        transition: width 0.3s ease;
      }
      #loader-text {
        font-family: system-ui, sans-serif;
        font-size: 11px; letter-spacing: 0.18em;
        color: rgba(255,255,255,0.35);
        text-transform: uppercase;
      }

    </style>
  </head>
  <body>
    <div id="loader">
      <div id="loader-text">Loading</div>
      <div id="loader-bar-wrap"><div id="loader-bar"></div></div>
    </div>
    <div id="c"><canvas id="cv"></canvas></div>


    <script>
      import * as THREE from "three";
      import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";

      const wrap      = document.getElementById("c")!;
      const canvas    = document.getElementById("cv") as HTMLCanvasElement;
      const loaderEl  = document.getElementById("loader")!;
      const loaderBar = document.getElementById("loader-bar")! as HTMLElement;

      // Track loading progress across two GLBs (each contributes 1/2)
      const progress = { rocket: 0, flame: 0 };
      function updateProgress() {
        const pct = (progress.rocket + progress.flame) / 2 * 100;
        loaderBar.style.width = `${Math.min(pct, 98)}%`;
      }
      function hideLoader() {
        loaderBar.style.width = '100%';
        setTimeout(() => loaderEl.classList.add('hidden'), 300);
      }


      // ── Renderer ──────────────────────────────────────────────────────────
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setClearColor(0x000000, 0);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.outputColorSpace = THREE.SRGBColorSpace;

      // ── Scene / camera ────────────────────────────────────────────────────
      const scene  = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, innerWidth / innerHeight, 0.01, 1000);
      camera.position.set(0, 0, 10);

      let bgMesh: THREE.Mesh | null = null;
      const starMats: THREE.PointsMaterial[] = [];

      // ── Background plane — 3D with mouse parallax ─────────────────────────
      // The plane sits at Z=-20 and shifts at a slower rate than the rocket,
      // creating perceivable depth separation between the two layers.
      function scaleBg() {
        if (!bgMesh) return;
        const dist = camera.position.z - bgMesh.position.z;           // 30 units
        const h = 2 * Math.tan(THREE.MathUtils.degToRad(camera.fov / 2)) * dist * 1.2;
        bgMesh.scale.set(h * camera.aspect, h, 1);
      }

      new THREE.TextureLoader().load('/sky-bg.png', (skyTex) => {
        skyTex.colorSpace = THREE.SRGBColorSpace;
        const bgMat = new THREE.MeshBasicMaterial({ map: skyTex, depthWrite: false });
        bgMesh = new THREE.Mesh(new THREE.PlaneGeometry(1, 1), bgMat);
        bgMesh.position.z = -20;
        bgMesh.renderOrder = -2;
        scene.add(bgMesh);
        scaleBg();
      });

      // ── Twinkling star field ───────────────────────────────────────────────
      // 12 groups × 80 stars. Each group has its own random blink speed and
      // max opacity so they feel independent. Pushed to Z -17…-24 (very far
      // behind the rocket) and sized at 0.03 world units (~1 pixel on screen).
      for (let g = 0; g < 12; g++) {
        const count = 40;
        const pos = new Float32Array(count * 3);
        for (let i = 0; i < count; i++) {
          pos[i*3]   = (Math.random() - 0.5) * 38;
          pos[i*3+1] = (Math.random() - 0.5) * 26;
          pos[i*3+2] = -17 - Math.random() * 7;   // Z -17…-24, deep background
        }
        const geo = new THREE.BufferGeometry();
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        const mat = new THREE.PointsMaterial({
          size: 0.03,
          color: 0xffffff,
          transparent: true,
          opacity: 0.0,
          depthWrite: false,
          depthTest: true,
          blending: THREE.AdditiveBlending,
          sizeAttenuation: true,
        });
        mat.userData.blinkSpeed  = 0.3 + Math.random() * 1.8;
        mat.userData.blinkPhase  = Math.random() * Math.PI * 2;
        mat.userData.minOpacity  = 0;
        mat.userData.maxOpacity  = 0.12 + Math.random() * 0.28;
        const pts = new THREE.Points(geo, mat);
        pts.renderOrder = -1;
        scene.add(pts);
        starMats.push(mat);
      }

      // ── Hero stars — 4 bright individual stars that slowly pulse ──────────
      // Spread across the sky in different quadrants, never fully fade out.
      const heroPositions = [
        [-8,  5, -19], [ 9,  7, -21],
        [-11, -4, -20], [ 6, -7, -18],
      ];
      heroPositions.forEach((p, i) => {
        const geo = new THREE.BufferGeometry();
        geo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(p), 3));
        const mat = new THREE.PointsMaterial({
          size: 0.09,
          color: 0xffffff,
          transparent: true,
          opacity: 0.5,
          depthWrite: false,
          depthTest: true,
          blending: THREE.AdditiveBlending,
          sizeAttenuation: true,
        });
        mat.userData.blinkSpeed = 0.12 + i * 0.07;
        mat.userData.blinkPhase = (i / 4) * Math.PI * 2;
        mat.userData.minOpacity = 0.25;
        mat.userData.maxOpacity = 0.90;
        const pts = new THREE.Points(geo, mat);
        pts.renderOrder = -1;
        scene.add(pts);
        starMats.push(mat);
      });

      // ── Environment map: milky-way image for surface reflections ──────────
      // Loaded independently so the rich star field / nebula colours reflect
      // across the rocket's metallic iridescent surface.
      new THREE.TextureLoader().load('/milky-way-full-stars-space.jpg', (envSrc) => {
        envSrc.mapping    = THREE.EquirectangularReflectionMapping;
        envSrc.colorSpace = THREE.SRGBColorSpace;
        const pmrem  = new THREE.PMREMGenerator(renderer);
        pmrem.compileEquirectangularShader();
        const envMap = pmrem.fromEquirectangular(envSrc).texture;
        scene.environment          = envMap;
        scene.environmentIntensity = 3.0;   // strong — pulls the nebula colours right onto the surface
        pmrem.dispose();
        envSrc.dispose();
      });




      // ── Mouse tilt ───────────────────────────────────────────────────
      const mouseTilt = { x: 0, y: 0, tx: 0, ty: 0 };
      window.addEventListener('mousemove', (e) => {
        mouseTilt.tx = (e.clientX / window.innerWidth  - 0.5) * 2;
        mouseTilt.ty = (e.clientY / window.innerHeight - 0.5) * 2;
      });

      // ── Lighting ──────────────────────────────────────────────────────
      const ambientLight = new THREE.AmbientLight(0xffffff, 2.0);
      scene.add(ambientLight);

      // Key light — front-top-right
      const dirLight = new THREE.DirectionalLight(0xffffff, 6.0);
      dirLight.position.set(1, 2, 2);
      scene.add(dirLight);

      // Fill light — left side, cool, lifts shadow areas
      const fillLight = new THREE.DirectionalLight(0xdde8ff, 5.0);
      fillLight.position.set(-2, 0.5, 1);
      scene.add(fillLight);

      // Rim light — back-top, edge highlight on the metal body
      const rimLight = new THREE.DirectionalLight(0xffffff, 4.0);
      rimLight.position.set(0, 3, -3);
      scene.add(rimLight);


      // ── Parallax motion particles ─────────────────────────────────────
      // Large debris/dust that streams from off-screen top to off-screen bottom,
      // always behind the rocket, creating the illusion of forward flight.
      // Matches Spline: PlaneEmitterShape (huge plane above scene), particles
      // drift in -bodyAxis direction, rocket occludes them via depth test.

      // Soft glow blob — visible as large background debris
      const _ptCv = document.createElement('canvas');
      _ptCv.width = _ptCv.height = 128;
      const _ptCtx = _ptCv.getContext('2d')!;
      const _ptGrad = _ptCtx.createRadialGradient(64, 64, 0, 64, 64, 62);
      _ptGrad.addColorStop(0,    'rgba(255,255,255,0.95)');
      _ptGrad.addColorStop(0.35, 'rgba(255,255,255,0.7)');
      _ptGrad.addColorStop(0.65, 'rgba(255,255,255,0.25)');
      _ptGrad.addColorStop(1.0,  'rgba(255,255,255,0.0)');
      _ptCtx.fillStyle = _ptGrad;
      _ptCtx.fillRect(0, 0, 128, 128);
      const _ptTex = new THREE.CanvasTexture(_ptCv);

      // Pool of 10 — wide spawn plane so only 1-3 land inside the viewport
      // at any given moment (matches Spline's large PlaneEmitterShape).
      const _PC       = 10;
      const _pLife    = new Float32Array(_PC);
      const _pMaxLife = 6.0;     // seconds — long enough to cross full screen height
      const _pPos     = new Float32Array(_PC * 3);
      const _pVelX    = new Float32Array(_PC);
      const _pVelY    = new Float32Array(_PC);
      const _pVelZ    = new Float32Array(_PC);
      let   _pBirthAcc = 0;
      const _BIRTH_IVL = 1.0 / 0.75;   // 0.75 per second (from Spline birthRatePerSec)

      for (let i = 0; i < _PC; i++) { _pPos[i*3+1] = 9999; }

      // Spawn a particle from off-screen above, behind the rocket in Z
      function _pBirth(i: number, ax: number, ay: number, az: number, preWarmY?: number) {
        const speed = 4.0 + Math.random() * 2.5;    // 4.0–6.5 u/s downward
        _pVelX[i] = -ax * speed;
        _pVelY[i] = -ay * speed;
        _pVelZ[i] = -az * speed;
        // Wide scatter on the plane perpendicular to bodyAxis
        const px = (Math.random() - 0.5) * 14;      // X: ±7 (wider than viewport ±4)
        const pz = -0.8 - Math.random() * 2.2;      // Z: -0.8 to -3 (behind rocket)
        const py = preWarmY !== undefined
          ? preWarmY                                  // pre-warm: spread within viewport
          : (6 + Math.random() * 4);                 // normal: 6–10 off-screen above
        _pPos[i*3]   = px;
        _pPos[i*3+1] = py;
        _pPos[i*3+2] = pz;
        _pLife[i] = _pMaxLife;
      }

      // Pre-warm 4 particles spread across the viewport so it isn't empty on load
      const _initAx = 0, _initAy = 1, _initAz = 0;
      for (let i = 0; i < 4; i++) {
        _pBirth(i, _initAx, _initAy, _initAz, -3 + Math.random() * 8);
        _pLife[i] = Math.random() * _pMaxLife;  // randomise remaining life
      }

      const _pGeo = new THREE.BufferGeometry();
      _pGeo.setAttribute('position', new THREE.BufferAttribute(_pPos, 3));
      const _pMat = new THREE.PointsMaterial({
        size: 0.9,
        map: _ptTex,
        color: new THREE.Color(0.807, 0.792, 0.798),
        transparent: true,
        opacity: 0.45,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
        depthTest: true,     // rocket renders in front — particles stay behind it
        sizeAttenuation: true,
      });
      const _pSystem = new THREE.Points(_pGeo, _pMat);
      scene.add(_pSystem);

      // ── Custom materials ──────────────────────────────────────────────
      // Fuselage: GLSL gradient driven by local vertex Y position.
      // Mesh 10 (Main fuselage) local Y range: -219.7 → 227.7
      // Colors match the reference: orange-red → pink → purple → blue → black nose
      const fuselageMat = new THREE.ShaderMaterial({
        vertexShader: /* glsl */`
          varying vec3 vPos;
          varying vec3 vNorm;
          varying vec3 vWorldPos;
          void main() {
            vPos      = position;
            vNorm     = normalMatrix * normal;
            vWorldPos = (modelMatrix * vec4(position, 1.0)).xyz;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
          }
        `,
        fragmentShader: /* glsl */`
          varying vec3 vPos;
          varying vec3 vNorm;
          varying vec3 vWorldPos;

          vec3 grad(float t) {
            if (t < 0.25) return mix(vec3(0.88, 0.86, 0.83), vec3(0.93, 0.92, 0.90), t / 0.25);
            if (t < 0.75) return mix(vec3(0.93, 0.92, 0.90), vec3(0.97, 0.97, 0.96), (t - 0.25) / 0.50);
            return mix(vec3(0.97, 0.97, 0.96), vec3(0.95, 0.94, 0.93), (t - 0.75) / 0.25);
          }

          void main() {
            float t   = clamp((vPos.y + 219.7) / 447.4, 0.0, 1.0);
            vec3  col = grad(t);
            vec3  n   = normalize(vNorm);

            float d   = max(dot(n, normalize(vec3(0.4, 0.8, 1.0))), 0.0);
            float f   = max(dot(n, normalize(vec3(0.0, -1.0, 0.3))), 0.0) * 0.25;
            float rim = pow(1.0 - max(dot(n, vec3(0.0, 0.0, 1.0)), 0.0), 4.0) * 0.35;
            col = col * (0.35 + d * 0.65 + f) + rim * vec3(0.25, 0.15, 0.70);

            // Gloss specular
            vec3 viewDir = normalize(cameraPosition - vWorldPos);
            vec3 halfVec = normalize(viewDir + normalize(vec3(0.4, 0.8, 1.0)));
            float spec   = pow(max(dot(n, halfVec), 0.0), 512.0);
            col += vec3(1.0) * spec * 1.2;

            gl_FragColor = vec4(col, 1.0);
          }
        `,
      });

      // Flame — animated displacement + gradient (dark tip → bright base)
      // Displacement strength ~17 units (from Spline settings), driven by time noise
      const flameUniforms = { time: { value: 0 } };

      const flameMat = new THREE.ShaderMaterial({
        uniforms: flameUniforms,
        depthWrite: true,
        depthTest: true,
        vertexShader: /* glsl */`
          uniform float time;
          varying vec3  vPos;
          varying vec3  vNorm;
          varying float vNoise;

          // ── Ashima Arts 3-D Simplex Noise ──────────────────────────────
          vec3 mod289v3(vec3 x){return x-floor(x*(1./289.))*289.;}
          vec4 mod289v4(vec4 x){return x-floor(x*(1./289.))*289.;}
          vec4 permute(vec4 x){return mod289v4(((x*34.)+10.)*x);}
          vec4 taylorInvSqrt(vec4 r){return 1.79284291400159-0.85373472095314*r;}

          float snoise(vec3 v){
            const vec2 C=vec2(1./6.,1./3.);
            vec3 i=floor(v+dot(v,C.yyy));
            vec3 x0=v-i+dot(i,C.xxx);
            vec3 g=step(x0.yzx,x0.xyz);
            vec3 l=1.-g;
            vec3 i1=min(g.xyz,l.zxy);
            vec3 i2=max(g.xyz,l.zxy);
            vec3 x1=x0-i1+C.xxx;
            vec3 x2=x0-i2+C.yyy;
            vec3 x3=x0-vec3(.5);
            i=mod289v3(i);
            vec4 p=permute(permute(permute(
              i.z+vec4(0.,i1.z,i2.z,1.))
             +i.y+vec4(0.,i1.y,i2.y,1.))
             +i.x+vec4(0.,i1.x,i2.x,1.));
            vec3 ns=vec3(1./7.)*(vec3(0.,5./7.,2./7.)*vec3(1.)-vec3(1./7.));
            vec4 j=p-49.*floor(p*(1./49.));
            vec4 x_=floor(j*(1./7.));
            vec4 y_=floor(j-7.*x_);
            vec4 x=x_*(1./7.)+ns.x;
            vec4 y=y_*(1./7.)+ns.x;
            vec4 h=1.-abs(x)-abs(y);
            vec4 b0=vec4(x.xy,y.xy);
            vec4 b1=vec4(x.zw,y.zw);
            vec4 s0=floor(b0)*2.+1.;
            vec4 s1=floor(b1)*2.+1.;
            vec4 sh=-step(h,vec4(0.));
            vec4 a0=b0.xzyw+s0.xzyw*sh.xxyy;
            vec4 a1=b1.xzyw+s1.xzyw*sh.zzww;
            vec3 p0=vec3(a0.xy,h.x);
            vec3 p1=vec3(a0.zw,h.y);
            vec3 p2=vec3(a1.xy,h.z);
            vec3 p3=vec3(a1.zw,h.w);
            vec4 norm=taylorInvSqrt(vec4(dot(p0,p0),dot(p1,p1),dot(p2,p2),dot(p3,p3)));
            p0*=norm.x; p1*=norm.y; p2*=norm.z; p3*=norm.w;
            vec4 m=max(.5-vec4(dot(x0,x0),dot(x1,x1),dot(x2,x2),dot(x3,x3)),0.);
            m=m*m;
            return 105.*dot(m*m,vec4(dot(p0,x0),dot(p1,x1),dot(p2,x2),dot(p3,x3)));
          }

          // fBm layered over Ashima simplex
          float fbm(vec3 p){
            float v=0.,a=.5;
            for(int i=0;i<4;i++){v+=a*snoise(p);p*=2.1;a*=.5;}
            return v;
          }

          void main(){
            vPos = position;

            float t = clamp((position.y + 224.0) / 448.0, 0.0, 1.0);

            // Spiral: rotate X/Z sampling coords by an angle that grows with height + time
            // This makes each height band sample a different rotational slice → helix ripples
            float spiral = t * 5.0 + time * 1.2;
            float cs = cos(spiral), sn = sin(spiral);
            float px = position.x / 448.0;
            float pz = position.z / 448.0;

            // Low frequency (scale 1.8) = large broad ripples
            float scale = 1.8;
            vec3 noiseCoord = vec3(
              (cs * px - sn * pz) * scale,
              t * scale + time * 2.5,        // scroll downward
              (sn * px + cs * pz) * scale + time * 0.4
            );

            vNoise = fbm(noiseCoord);
            float ampT = mix(0.4, 1.0, t);
            float disp = vNoise * 70.0 * ampT;

            // Compute displaced surface normals via finite-difference tangent vectors.
            // Step e units in world-space X and Z; the corresponding noise-coord
            // delta accounts for the spiral rotation so the gradient is accurate.
            float e  = 12.0;
            float kx = scale / 448.0;
            float n_x = fbm(noiseCoord + vec3( cs * kx, 0.0,  sn * kx) * e);
            float n_z = fbm(noiseCoord + vec3(-sn * kx, 0.0,  cs * kx) * e);
            vec3 tangX = vec3(e, 0.0, 0.0) + normal * (n_x - vNoise) * 70.0 * ampT;
            vec3 tangZ = vec3(0.0, 0.0, e) + normal * (n_z - vNoise) * 70.0 * ampT;
            vec3 displacedNorm = normalize(cross(tangZ, tangX));

            vec3 displaced = position + normal * disp;
            // Slight taper near nozzle: 100% width at tip, ~82% at nozzle end
            float taper = mix(1.0, 0.82, t);
            displaced.x *= taper;
            displaced.z *= taper;
            vNorm       = normalMatrix * displacedNorm;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(displaced, 1.0);
          }
        `,
        fragmentShader: /* glsl */`
          varying vec3  vPos;
          varying vec3  vNorm;
          varying float vNoise;

          void main() {
            float t = clamp((vPos.y + 224.0) / 448.0, 0.0, 1.0);

            // Noise shifts where each pixel sits on the gradient — color bands
            // ripple organically with the displacement instead of being flat rings
            float tColor = clamp(t + vNoise * 0.20, 0.0, 1.0);

            vec3 col;
            if      (tColor < 0.28) col = mix(vec3(1.00, 1.00, 1.00), vec3(2.00, 1.80, 0.10), tColor / 0.28);
            else if (tColor < 0.80) col = mix(vec3(2.00, 1.80, 0.10), vec3(1.80, 1.40, 0.05), (tColor - 0.28) / 0.52);
            else if (tColor < 0.92) col = mix(vec3(1.80, 1.40, 0.05), vec3(0.88, 0.18, 0.04), (tColor - 0.80) / 0.12);
            else                    col = mix(vec3(0.88, 0.18, 0.04), vec3(0.68, 0.04, 0.02), (tColor - 0.92) / 0.08);

            col *= (1.3 - t * 0.3);

            // Sharpen contrast: peaks bright, valleys dark (internal shadow look)
            float hotspot = pow(clamp(vNoise * 0.5 + 0.5, 0.0, 1.0), 1.5);
            vec3 valleyCol = mix(vec3(0.85, 0.04, 0.02), vec3(0.65, 0.06, 0.02), smoothstep(0.0, 0.40, hotspot));
            col = mix(valleyCol, col * vec3(1.4, 1.1, 0.8), hotspot);
            // Emissive: only the brightest peaks self-illuminate like glowing fire
            float emit = smoothstep(0.68, 1.0, hotspot);
            col += emit * vec3(0.95, 0.55, 0.10) * 0.6;
            // White highlight on the very top of displacement peaks
            float peakWhite = smoothstep(0.30, 1.0, hotspot);
            col += peakWhite * vec3(1.0, 1.0, 1.0) * 0.5;

            // Bottom tip → white (only bottom 10%)
            float bottomGlow = smoothstep(0.20, 0.0, t);
            col = mix(col, vec3(1.3, 1.3, 1.2), bottomGlow * 0.9);

            vec3 n = normalize(vNorm);
            float diff    = max(dot(n, normalize(vec3(1.0, 0.2, 0.3))), 0.0);
            float facing  = max(dot(n, vec3(0.0, 0.0, 1.0)), 0.0);
            float rim     = 1.0 - facing;

            // Core darker than outer shell
            float coreDark = mix(0.55, 1.0, pow(rim, 1.5));
            col = col * (0.60 + diff * 0.40) * coreDark;

            // Moderate rim glow — same ballpark as original fresnel
            float fresnel = pow(rim, 2.5) * 0.60;
            col += fresnel * vec3(1.0, 0.50, 0.10);

            // Dark long red rectangles — front-facing and directly behind, upper flame
            float ang = atan(vPos.x, vPos.z);
            float frontStripe = smoothstep(0.65, 0.05, abs(ang));
            float backStripe  = smoothstep(0.65, 0.05, 3.14159 - abs(ang));
            float heightMask  = smoothstep(0.38, 0.58, t) * smoothstep(1.02, 0.86, t);
            float rectMask    = max(frontStripe, backStripe) * heightMask;
            col = mix(col, vec3(0.90, 0.05, 0.02), rectMask * 0.36);

            // Nozzle hole at top
            float nozzleHole = facing * smoothstep(0.25, 1.0, t) * 0.60;
            col *= (1.0 - nozzleHole);

            gl_FragColor = vec4(col, 1.0);
          }
        `,
      });

      // Solid PBR materials for the remaining parts
      const windowMat = new THREE.MeshStandardMaterial({
        color: 0x06080c, emissive: 0x000204, roughness: 0.08, metalness: 0.15,
      });
      const edgeMat = new THREE.MeshStandardMaterial({
        color: 0x111118, roughness: 0.85, metalness: 0,
      });
      const finsMat = new THREE.MeshStandardMaterial({
        color: 0xa5271d, roughness: 0.45, metalness: 0,
      });

      // ── Fuselage / fins: near-mirror MeshStandardMaterial + gradient ─────
      // metalness≈1, roughness≈0 → studio HDR reflects across the surface.
      // onBeforeCompile injects the gradient colour into the PBR diffuse slot
      // so the gradient tints the reflections rather than replacing them.

      // baseMx = mesh.matrixWorld captured before pivot tilt is applied,
      // so the gradient Y is always in untilted rocket space.
      function makeFuselageMat(yMin: number, yMax: number, baseMx: THREE.Matrix4) {
        const mat = new THREE.MeshPhysicalMaterial({
          metalness: 0.3,
          roughness: 0.45,
          clearcoat: 0.4,
          clearcoatRoughness: 0.35,
          envMapIntensity: 2.0,
        });
        mat.customProgramCacheKey = () => `fuse_${yMin.toFixed(1)}_${yMax.toFixed(1)}`;
        mat.onBeforeCompile = (shader: any) => {
          shader.uniforms.yMin   = { value: yMin };
          shader.uniforms.yMax   = { value: yMax };
          shader.uniforms.baseMx = { value: baseMx };
          shader.vertexShader = shader.vertexShader
            .replace('#include <common>', `#include <common>
uniform float yMin; uniform float yMax;
uniform mat4  baseMx;
varying float vGradT;`)
            .replace('#include <begin_vertex>', `#include <begin_vertex>
vec3 rp = (baseMx * vec4(position,1.0)).xyz;
float rawT = (rp.y - yMin) / (yMax - yMin);
float ang = atan(rp.x, rp.z);
float sway = sin(ang*2.0)*0.018 + sin(ang*5.0+0.9)*0.010 + sin(ang*9.0+2.3)*0.005;
vGradT = clamp(rawT + sway, 0.0, 1.0);`);
          shader.fragmentShader = shader.fragmentShader
            .replace('#include <common>', `#include <common>
varying float vGradT;
vec3 fuseGrad(float t){
  // White body — warm at engine end, clean bright white through the body
  if(t<0.20) return mix(vec3(0.88,0.85,0.82),vec3(0.93,0.91,0.89),t/0.20);
  if(t<0.80) return mix(vec3(0.93,0.91,0.89),vec3(0.97,0.97,0.96),(t-0.20)/0.60);
  return     mix(vec3(0.97,0.97,0.96),vec3(0.95,0.94,0.93),(t-0.80)/0.20);
}`)
            .replace('vec4 diffuseColor = vec4( diffuse, opacity );',
              `vec3 _gc = fuseGrad(vGradT);
float _lum = dot(_gc, vec3(0.2126,0.7152,0.0722));
_gc = clamp(mix(vec3(_lum), _gc, 1.4), 0.0, 1.0);
vec4 diffuseColor = vec4(_gc, opacity);`);
        };
        return mat;
      }

      // Plain mirror silver nozzle
      function makeNozzleMat(_yMin: number, _yMax: number) {
        return new THREE.MeshPhysicalMaterial({
          color: 0xd4d8dc,
          metalness: 0.9,
          roughness: 0.15,
          envMapIntensity: 16.0,
          clearcoat: 1.0,
          clearcoatRoughness: 0.0,
        });
      }

      function makeFinMat(yMin: number, yMax: number, baseMx: THREE.Matrix4) {
        return new THREE.ShaderMaterial({
          uniforms: {
            yMin:   { value: yMin },
            yMax:   { value: yMax },
            baseMx: { value: baseMx },
          },
          vertexShader: /* glsl */`
            uniform float yMin, yMax;
            uniform mat4  baseMx;
            varying float vT;
            varying vec3  vNorm;
            varying vec3  vWorldPos;
            void main() {
              float preY = (baseMx * vec4(position, 1.0)).y;
              vT       = clamp((preY - yMin) / (yMax - yMin), 0.0, 1.0);
              vNorm    = normalMatrix * normal;
              vWorldPos = (modelMatrix * vec4(position, 1.0)).xyz;
              gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
            }
          `,
          fragmentShader: /* glsl */`
            varying float vT;
            varying vec3  vNorm;
            varying vec3  vWorldPos;
            vec3 finGrad(float t) {
              // bottom: warm bright red, top: dark red — no white
              if(t<0.50) return mix(vec3(0.90,0.22,0.12), vec3(0.65,0.10,0.07), t/0.50);
              return mix(vec3(0.65,0.10,0.07), vec3(0.32,0.07,0.05), (t-0.50)/0.50);
            }
            void main() {
              vec3 col = finGrad(vT);
              vec3 n = normalize(vNorm);
              float d   = max(dot(n, normalize(vec3(0.4, 0.8, 1.0))), 0.0);
              float f   = max(dot(n, normalize(vec3(0.0,-1.0, 0.3))), 0.0) * 0.25;
              float rim = pow(1.0 - max(dot(n, vec3(0.0,0.0,1.0)), 0.0), 4.0) * 0.30;
              col = col * (0.35 + d*0.65 + f) + rim * vec3(0.60,0.10,0.10);

              // Gloss specular
              vec3 viewDir = normalize(cameraPosition - vWorldPos);
              vec3 halfVec = normalize(viewDir + normalize(vec3(0.4, 0.8, 1.0)));
              float spec   = pow(max(dot(n, halfVec), 0.0), 512.0);
              col += vec3(1.0) * spec * 1.2;

              gl_FragColor = vec4(col, 1.0);
            }
          `,
        });
      }

      // ── Strip texture from rocket fuselage + fins ─────────────────────
      function customizeRocketMaterials(
        root: THREE.Object3D, worldYMin: number, worldYMax: number
      ): { window: { center: THREE.Vector3; size: THREE.Vector3 } | null; nozzle: { center: THREE.Vector3; size: THREE.Vector3 } | null } {
        let windowCenter: THREE.Vector3 | null = null;
        let windowSize: THREE.Vector3 | null = null;
        let nozzleCenter: THREE.Vector3 | null = null;
        let nozzleSize: THREE.Vector3 | null = null;
        const rootBox  = new THREE.Box3().setFromObject(root);
        const rootSize = rootBox.getSize(new THREE.Vector3());
        const rootCtr  = rootBox.getCenter(new THREE.Vector3());

        root.traverse((child) => {
          const mesh = child as THREE.Mesh;
          if (!mesh.isMesh) return;

          const wb  = new THREE.Box3().setFromObject(mesh);
          const ws  = wb.getSize(new THREE.Vector3());
          const wc  = wb.getCenter(new THREE.Vector3());
          const lat = Math.sqrt((wc.x - rootCtr.x) ** 2 + (wc.z - rootCtr.z) ** 2);
          const hRatio  = ws.y / rootSize.y;
          const maxLat  = Math.max(ws.x, ws.z);
          const flatness = ws.y / (maxLat + 0.0001);

          // Fuselage: tall (>30% rocket height), taller than wide, near axis
          const isFuselage = hRatio > 0.30 && flatness > 1.0 && lat < rootSize.x * 0.3;

          // Fins: in lower half, laterally offset
          const isFin = wc.y < rootCtr.y
            && lat > rootSize.x * 0.06
            && hRatio < 0.55
            && maxLat > rootSize.x * 0.08;

          // Nozzle: centred on axis, in lower half, shorter than fuselage
          const isNozzle = wc.y < rootCtr.y
            && lat < rootSize.x * 0.14
            && hRatio < 0.28;

          if (isFuselage) {
            mesh.updateWorldMatrix(true, false);
            mesh.material = makeFuselageMat(worldYMin, worldYMax, mesh.matrixWorld.clone());
          } else if (isFin) {
            mesh.updateWorldMatrix(true, false);
            mesh.material = makeFinMat(wb.min.y, wb.max.y, mesh.matrixWorld.clone());
          } else if (isNozzle) {
            nozzleCenter = wc.clone();
            nozzleSize = ws.clone();
            mesh.material = makeNozzleMat(wb.min.y, wb.max.y);
          } else {
            // Window frame assemblies: large laterally-offset meshes in the upper half → aluminium silver
            const isWindowFrame = hRatio > 0.13 && lat > 0.60 && wc.y > rootCtr.y;
            // Nose cone: centred mesh whose top touches the rocket tip
            const isNoseCone = wc.y > rootCtr.y
              && wb.max.y > rootBox.max.y - rootSize.y * 0.06
              && lat < rootSize.x * 0.35
              && hRatio < 0.50;

            if (isWindowFrame) {
              windowCenter = wc.clone();
              windowSize = ws.clone();
              mesh.material = new THREE.MeshPhysicalMaterial({
                color: 0xff5500,
                roughness: 0.05,
                metalness: 0.7,
                envMapIntensity: 12.0,
                clearcoat: 1.0,
                clearcoatRoughness: 0.0,
              });
            } else if (isNoseCone) {
              mesh.layers.enable(1);
              mesh.material = new THREE.MeshPhysicalMaterial({
                color: 0xa5271d,
                roughness: 0.0,
                metalness: 0.0,
                clearcoat: 1.0,
                clearcoatRoughness: 0.0,
                envMapIntensity: 2.0,
              });
            } else {
              // Portholes — real glass: transmission + IOR, no textures
              mesh.material = new THREE.MeshPhysicalMaterial({
                color: 0x0f1f5c,
                transmission: 1.0,
                transparent: true,
                roughness: 0.0,
                metalness: 0.0,
                ior: 1.5,
                thickness: 1.0,
                attenuationColor: new THREE.Color(0x0a1845),
                attenuationDistance: 0.4,
                clearcoat: 1.0,
                clearcoatRoughness: 0.0,
                envMapIntensity: 1.5,
                side: THREE.DoubleSide,
              });
            }
          }
        });
        return {
          window: windowCenter && windowSize ? { center: windowCenter, size: windowSize } : null,
          nozzle: nozzleCenter && nozzleSize ? { center: nozzleCenter, size: nozzleSize } : null,
        };
      }

      // ── Material assignment by (sanitised) mesh name ───────────────────
      // GLTFLoader sanitises: spaces→underscore, removes non-word chars
      function applyMaterials(root: THREE.Object3D) {
        root.traverse((child) => {
          const mesh = child as THREE.Mesh;
          if (!mesh.isMesh) return;

          const name = mesh.name;
          if (name === "Main_fuselage")  { mesh.material = fuselageMat; return; }
          if (name === "Cylinder")       { mesh.material = flameMat;    return; }
          if (name === "Window")         { mesh.material = windowMat;   return; }
          if (name === "Window_edge")    { mesh.material = edgeMat;     return; }
          // Fins are unnamed meshes
          mesh.material = finsMat;
        });
      }

      // ── Load both GLBs in parallel ────────────────────────────────
      const loader = new GLTFLoader();
      let pivot: THREE.Group | null = null;
      let spinGroup: THREE.Group | null = null;
      let rocketBodyAxis: THREE.Vector3 = new THREE.Vector3(0, 1, 0);

      const loadGLB = (url: string, onProg?: (n: number) => void) =>
        new Promise<any>((res, rej) =>
          loader.load(url, res, (e: ProgressEvent) => {
            if (e.lengthComputable && onProg) onProg(e.loaded / e.total);
          }, rej)
        );

      Promise.all([
        loadGLB("/Final_texture_spline_smooth_rocket.glb", (n) => { progress.rocket = n; updateProgress(); }),
        loadGLB("/toy_rocket.glb",    (n) => { progress.flame  = n; updateProgress(); }),
      ])
        .then(([rocketGltf, flameGltf]) => {

          // ── Rocket body ───────────────────────────────────────────
          const rocketRoot = rocketGltf.scene as THREE.Group;

          // Fit rocket to 4 scene units
          const rb1   = new THREE.Box3().setFromObject(rocketRoot);
          const rSize = rb1.getSize(new THREE.Vector3());
          const rk    = 4.0 / Math.max(rSize.x, rSize.y, rSize.z);
          rocketRoot.scale.multiplyScalar(rk);

          // Centre rocket at origin
          const rb2   = new THREE.Box3().setFromObject(rocketRoot);
          const rCtr  = rb2.getCenter(new THREE.Vector3());
          rocketRoot.position.sub(rCtr);

          const rb3    = new THREE.Box3().setFromObject(rocketRoot);
          const rHeight = rb3.max.y - rb3.min.y;

          // ── Iridescent / glossy material upgrade ──────────────────────────
          // Replace MeshStandardMaterial with MeshPhysicalMaterial keeping all
          // existing GLB texture maps, then layer iridescence on top.
          rocketRoot.traverse((o: THREE.Object3D) => {
            const mesh = o as THREE.Mesh;
            if (!mesh.isMesh || !mesh.material) return;
            const upgrade = (mat: THREE.Material): THREE.MeshPhysicalMaterial => {
              const s = mat as THREE.MeshStandardMaterial;
              return new THREE.MeshPhysicalMaterial({
                map:              s.map,
                normalMap:        s.normalMap,
                // roughnessMap / metalnessMap nulled so our scalar values are
                // fully in control — GLB baked maps were overriding them on
                // fins, nozzle and nose cone, killing reflections there.
                roughnessMap:     null,
                metalnessMap:     null,
                aoMap:            s.aoMap,
                emissiveMap:      s.emissiveMap,
                emissive:         s.emissive?.clone() ?? new THREE.Color(0x000000),
                emissiveIntensity: s.emissiveIntensity ?? 0,
                color:            s.color?.clone() ?? new THREE.Color(0xffffff),
                roughness:        0.05,
                metalness:        0.82,
                envMapIntensity:  6.0,
                // Iridescence — thin-film interference, angle-dependent colour shift
                iridescence:               0.35,
                iridescenceIOR:            1.3,
                iridescenceThicknessRange: [100, 400],
              });
            };
            if (Array.isArray(mesh.material)) {
              mesh.material = mesh.material.map(upgrade);
            } else {
              mesh.material = upgrade(mesh.material);
            }
          });

          // ── Apply fin gradient shader (overrides iridescence upgrade on fins) ──
          {
            rocketRoot.updateWorldMatrix(false, true);
            const _rb  = new THREE.Box3().setFromObject(rocketRoot);
            const _rs  = _rb.getSize(new THREE.Vector3());
            const _rc  = _rb.getCenter(new THREE.Vector3());
            rocketRoot.traverse((o: THREE.Object3D) => {
              const mesh = o as THREE.Mesh;
              if (!mesh.isMesh) return;
              const wb    = new THREE.Box3().setFromObject(mesh);
              const ws    = wb.getSize(new THREE.Vector3());
              const wc    = wb.getCenter(new THREE.Vector3());
              const lat      = Math.sqrt((wc.x - _rc.x) ** 2 + (wc.z - _rc.z) ** 2);
              const hRatio   = ws.y / _rs.y;
              const maxLat   = Math.max(ws.x, ws.z);
              const flatness = ws.y / (maxLat + 0.0001);
              const isFin  = wc.y < _rc.y
                && lat    > _rs.x * 0.06
                && hRatio < 0.55
                && maxLat > _rs.x * 0.08;
              const isFuselage = hRatio > 0.30 && flatness > 1.0 && lat < _rs.x * 0.3;
              if (isFin) {
                mesh.updateWorldMatrix(true, false);
                const _yMin   = wb.min.y;
                const _yMax   = wb.max.y;
                const _baseMx = mesh.matrixWorld.clone();
                const finMat  = mesh.material as THREE.MeshPhysicalMaterial;
                finMat.onBeforeCompile = (shader) => {
                  shader.uniforms.yMin   = { value: _yMin };
                  shader.uniforms.yMax   = { value: _yMax };
                  shader.uniforms.baseMx = { value: _baseMx };
                  shader.vertexShader = shader.vertexShader
                    .replace('#include <common>',
                      `#include <common>
uniform mat4  baseMx;
uniform float yMin, yMax;
varying float vFinT;`)
                    .replace('#include <begin_vertex>',
                      `#include <begin_vertex>
float _pY = (baseMx * vec4(position, 1.0)).y;
vFinT = clamp((_pY - yMin) / (yMax - yMin), 0.0, 1.0);`);
                  shader.fragmentShader = shader.fragmentShader
                    .replace('#include <common>',
                      `#include <common>
varying float vFinT;`)
                    .replace('#include <dithering_fragment>',
                      `#include <dithering_fragment>
gl_FragColor.rgb *= mix(1.6, 0.5, vFinT);`);
                };
                finMat.needsUpdate = true;
              } else if (isFuselage) {
                // ── Fuselage: show base colour on left side + lower nozzle area ──
                // Reduces metalness on world-left-facing normals and the bottom
                // portion of the body, letting the original texture colour through.
                mesh.updateWorldMatrix(true, false);
                const _yMin   = wb.min.y;
                const _yMax   = wb.max.y;
                const _baseMx = mesh.matrixWorld.clone();
                const fuseMat = mesh.material as THREE.MeshPhysicalMaterial;
                fuseMat.onBeforeCompile = (shader) => {
                  shader.uniforms.yMin   = { value: _yMin };
                  shader.uniforms.yMax   = { value: _yMax };
                  shader.uniforms.baseMx = { value: _baseMx };
                  shader.vertexShader = shader.vertexShader
                    .replace('#include <common>', `#include <common>
uniform mat4  baseMx;
uniform float yMin, yMax;
varying float vFuseT;
varying vec3  vWNorm;`)
                    .replace('#include <begin_vertex>', `#include <begin_vertex>
vec4 _wp = baseMx * vec4(position, 1.0);
vFuseT  = clamp((_wp.y - yMin) / (yMax - yMin), 0.0, 1.0);
vWNorm  = normalize(mat3(modelMatrix) * objectNormal);`);
                  shader.fragmentShader = shader.fragmentShader
                    .replace('#include <common>', `#include <common>
varying float vFuseT;
varying vec3  vWNorm;`)
                    .replace('#include <metalnessmap_fragment>', `#include <metalnessmap_fragment>
float _leftB   = smoothstep(-0.1, -0.9, vWNorm.x);
float _botB    = smoothstep(0.14, 0.32, vFuseT) * smoothstep(0.58, 0.26, vFuseT);
float _cBlend  = clamp(_leftB * 0.38 + _botB * 0.55, 0.0, 0.45);
metalnessFactor = mix(metalnessFactor, 0.48, _cBlend);
roughnessFactor = mix(roughnessFactor, 0.25, _cBlend * 0.4);`);
                };
                fuseMat.needsUpdate = true;
              }
            });
          }


          // Spline bakes the tilt into geometry vertices — rocketRoot.quaternion is
          // identity. The body axis comes from the bounding-box centres of the two
          // rotationally-symmetric meshes confirmed via dev-tools:
          //   polySurface4 = nose cone   (bbox centre z=0.000)
          //   polySurface5 = fuselage body (bbox centre z=0.000, spans nose→nozzle)
          // Using bbox centres avoids the PCA chicken-and-egg: projecting onto a
          // wrong axis biases the nozzle cluster toward one side of the exit ring.
          rocketRoot.updateWorldMatrix(false, true);

          // Pass 1: bbox centres of the two on-axis meshes → correct bodyAxis (z≈0)
          const _poly4Cen = new THREE.Vector3(), _poly5Cen = new THREE.Vector3();
          let _has4 = false, _has5 = false;
          rocketRoot.traverse((o: THREE.Object3D) => {
            const m = o as THREE.Mesh;
            if (!m.isMesh) return;
            if (m.name === 'polySurface4') {
              new THREE.Box3().setFromObject(m).getCenter(_poly4Cen); _has4 = true;
            }
            if (m.name === 'polySurface5') {
              new THREE.Box3().setFromObject(m).getCenter(_poly5Cen); _has5 = true;
            }
          });

          // Body axis = polySurface5 centre → polySurface4 centre (both z=0 → axis z≈0)
          const bodyAxis = new THREE.Vector3(0, 1, 0);
          if (_has4 && _has5) {
            bodyAxis.copy(_poly4Cen.clone().sub(_poly5Cen).normalize());
            if (bodyAxis.y < 0) bodyAxis.negate();
          }

          // Pass 2: find nose tip (max proj of polySurface4) and
          //         nozzle exit ring centroid (min proj cluster of polySurface5)
          // With the correct bodyAxis the projection is unbiased and nozzleCen.z ≈ 0.
          const _noseTipV = new THREE.Vector3();
          const _nozzCen  = new THREE.Vector3();
          let   _nozzN    = 0;

          rocketRoot.traverse((o: THREE.Object3D) => {
            const m = o as THREE.Mesh;
            if (!m.isMesh || !m.geometry?.attributes?.position) return;
            const pa = m.geometry.attributes.position as THREE.BufferAttribute;

            if (m.name === 'polySurface4') {
              let _best = -Infinity;
              for (let i = 0; i < pa.count; i++) {
                const v = new THREE.Vector3().fromBufferAttribute(pa, i).applyMatrix4(m.matrixWorld);
                const p = v.dot(bodyAxis);
                if (p > _best) { _best = p; _noseTipV.copy(v); }
              }
            }

            if (m.name === 'polySurface5') {
              let _minP = Infinity;
              for (let i = 0; i < pa.count; i++) {
                const v = new THREE.Vector3().fromBufferAttribute(pa, i).applyMatrix4(m.matrixWorld);
                const p = v.dot(bodyAxis);
                if (p < _minP) _minP = p;
              }
              // Average vertices within 0.15 world units of the minimum (≈ nozzle exit ring)
              for (let i = 0; i < pa.count; i++) {
                const v = new THREE.Vector3().fromBufferAttribute(pa, i).applyMatrix4(m.matrixWorld);
                if (v.dot(bodyAxis) < _minP + 0.15) { _nozzCen.add(v); _nozzN++; }
              }
              if (_nozzN > 0) _nozzCen.divideScalar(_nozzN);
            }
          });

          // Collect centroid for debug mesh projections only (not used for axis/position)
          const _pcaV: THREE.Vector3[] = [];
          rocketRoot.traverse((o: THREE.Object3D) => {
            const m = o as THREE.Mesh;
            if (!m.isMesh || !m.geometry?.attributes?.position) return;
            const pa   = m.geometry.attributes.position as THREE.BufferAttribute;
            const step = Math.max(1, Math.floor(pa.count / 200));
            for (let i = 0; i < pa.count; i += step)
              _pcaV.push(new THREE.Vector3().fromBufferAttribute(pa, i).applyMatrix4(m.matrixWorld));
          });
          const _pcaCen = new THREE.Vector3();
          _pcaV.forEach(v => _pcaCen.add(v));
          _pcaCen.divideScalar(_pcaV.length);

          const _bodyLen    = _noseTipV.distanceTo(_nozzCen);
          const halfBodyLen = _bodyLen * 0.5;
          const nozzleWorld = _nozzCen.clone();
          rocketBodyAxis.copy(bodyAxis);

          // ── DEBUG logs (open browser console / F12) ───────────────
          console.log('=== ROCKET AXIS DEBUG ===');
          console.log('rocketRoot.quaternion xyzw:',
            rocketRoot.quaternion.x.toFixed(4), rocketRoot.quaternion.y.toFixed(4),
            rocketRoot.quaternion.z.toFixed(4), rocketRoot.quaternion.w.toFixed(4));
          console.log('poly4Cen:', _poly4Cen.x.toFixed(4), _poly4Cen.y.toFixed(4), _poly4Cen.z.toFixed(4));
          console.log('poly5Cen:', _poly5Cen.x.toFixed(4), _poly5Cen.y.toFixed(4), _poly5Cen.z.toFixed(4));
          console.log('bodyAxis (from bbox centres):', bodyAxis.x.toFixed(4), bodyAxis.y.toFixed(4), bodyAxis.z.toFixed(4));
          console.log('noseTipV:', _noseTipV.x.toFixed(4), _noseTipV.y.toFixed(4), _noseTipV.z.toFixed(4));
          console.log('nozzleCen:', _nozzCen.x.toFixed(4), _nozzCen.y.toFixed(4), _nozzCen.z.toFixed(4));
          console.log('body length (world units):', _bodyLen.toFixed(4));
          console.log('--- mesh world bounding boxes (sorted nose→nozzle) ---');
          const _meshInfos: {name:string, cx:number, cy:number, cz:number, proj:number}[] = [];
          rocketRoot.traverse((o: THREE.Object3D) => {
            const m = o as THREE.Mesh;
            if (!m.isMesh) return;
            const _bb = new THREE.Box3().setFromObject(m);
            const _bc = _bb.getCenter(new THREE.Vector3());
            _meshInfos.push({
              name: m.name,
              cx: _bc.x, cy: _bc.y, cz: _bc.z,
              proj: _bc.clone().sub(_pcaCen).dot(bodyAxis)
            });
          });
          _meshInfos.sort((a, b) => b.proj - a.proj);
          _meshInfos.forEach(mi =>
            console.log(`  [proj ${mi.proj.toFixed(3)}] "${mi.name}" centre: ${mi.cx.toFixed(3)} ${mi.cy.toFixed(3)} ${mi.cz.toFixed(3)}`)
          );
          console.log('=========================');
          // ─────────────────────────────────────────────────────────

          const nozzleY  = nozzleWorld.y;
          const nozzleCx = nozzleWorld.x;
          const nozzleCz = nozzleWorld.z;


          // ── Flame ─────────────────────────────────────────────────
          const flameRoot = flameGltf.scene as THREE.Group;
          flameRoot.updateWorldMatrix(false, true);

          let flameGroup: THREE.Object3D | undefined;
          flameRoot.traverse((c: THREE.Object3D) => { if (c.name === "Flame") flameGroup = c; });
          if (!flameGroup) { console.error("Flame node not found"); return; }

          // Full clean slate — no inherited position, rotation, or scale.
          // Using ws from matrixWorld caused non-uniform scale → shear → flame
          // appeared at a different angle from every camera direction.
          flameGroup.removeFromParent();
          flameGroup.position.set(0, 0, 0);
          flameGroup.quaternion.set(0, 0, 0, 1);
          flameGroup.scale.set(1, 1, 1);

          applyMaterials(flameGroup);

          // Scale to 90% of rocket height — uniform scale, no shear
          const fb1   = new THREE.Box3().setFromObject(flameGroup);
          const fSize = fb1.getSize(new THREE.Vector3());
          // Use true body length from PCA (not world-AABB height which is shorter when tilted)
          const fk    = (_bodyLen * 0.90) / fSize.y;
          flameGroup.scale.setScalar(fk);

          // Flame's attachment end = max Y in flame's own local space (y=+224 per shader)
          const fLocalMaxY = fb1.max.y;

          // Rotate flame so its local +Y aligns with the PCA-derived body axis
          flameGroup.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), bodyAxis);

          // Place flame so its attachment end sits at nozzle + 5 % overlap along body axis
          const overlapDist = fk * fSize.y * 0.05;
          flameGroup.position.copy(nozzleWorld)
            .addScaledVector(bodyAxis, overlapDist - fk * fLocalMaxY);

          const tiltGroup = new THREE.Group();
          tiltGroup.add(rocketRoot);
          tiltGroup.add(flameGroup);


          // spinGroup is now the OUTER group — it spins around world Y (true vertical)
          // tiltGroup sits inside it and just applies the cosmetic lean
          spinGroup = new THREE.Group();
          spinGroup.add(tiltGroup);

          pivot = new THREE.Group();
          pivot.add(spinGroup);
          scene.add(pivot);

          wrap.classList.add("ready");
          hideLoader();
        })
        .catch((e: any) => console.error("GLB load error:", e));

      // ── Render loop ───────────────────────────────────────────────────
      const clock = new THREE.Clock();
      let prevT = 0;
      (function animate() {
        requestAnimationFrame(animate);
        const t  = clock.getElapsedTime();
        const dt = Math.min(t - prevT, 0.05);
        prevT = t;

        // Smooth mouse tilt
        mouseTilt.x += (mouseTilt.tx - mouseTilt.x) * 0.04;
        mouseTilt.y += (mouseTilt.ty - mouseTilt.y) * 0.04;

        // Background parallax — moves at ~25% of rocket tilt, opposite direction
        if (bgMesh) {
          bgMesh.position.x += (-mouseTilt.x * 1.8 - bgMesh.position.x) * 0.04;
          bgMesh.position.y += ( mouseTilt.y * 1.2 - bgMesh.position.y) * 0.04;
        }

        if (spinGroup) {
          spinGroup.quaternion.setFromAxisAngle(rocketBodyAxis, t * 2.0);
        }

        if (pivot) {
          const floatAmt = Math.sin(t * 1.2) * 0.6;
          pivot.position.copy(rocketBodyAxis).multiplyScalar(floatAmt);
          pivot.rotation.z = mouseTilt.x * -0.35;
          pivot.rotation.x = mouseTilt.y *  0.25;
        }

        flameUniforms.time.value = t;

        // Each group/star blinks at its own speed; hero stars use minOpacity floor
        starMats.forEach((mat) => {
          const { blinkSpeed, blinkPhase, minOpacity, maxOpacity } = mat.userData;
          mat.opacity = minOpacity + (maxOpacity - minOpacity) * (0.5 + 0.5 * Math.sin(t * blinkSpeed + blinkPhase));
        });

        // ── Parallax motion particles ─────────────────────────────────
        {
          const _pAttr = _pGeo.attributes.position as THREE.BufferAttribute;
          const ax = rocketBodyAxis.x, ay = rocketBodyAxis.y, az = rocketBodyAxis.z;

          // Spawn new particles from above at 0.75/s
          _pBirthAcc += dt;
          if (_pBirthAcc >= _BIRTH_IVL) {
            _pBirthAcc -= _BIRTH_IVL;
            let slot = -1;
            for (let i = 0; i < _PC; i++) { if (_pLife[i] <= 0) { slot = i; break; } }
            if (slot >= 0) _pBirth(slot, ax, ay, az);
          }

          for (let i = 0; i < _PC; i++) {
            if (_pLife[i] <= 0) continue;
            _pLife[i] -= dt;
            if (_pLife[i] <= 0) {
              _pPos[i*3] = _pPos[i*3+1] = _pPos[i*3+2] = 9999;
              continue;
            }
            _pPos[i*3]   += _pVelX[i] * dt;
            _pPos[i*3+1] += _pVelY[i] * dt;
            _pPos[i*3+2] += _pVelZ[i] * dt;
          }
          _pAttr.needsUpdate = true;
        }

        renderer.render(scene, camera);
      })();

      window.addEventListener("resize", () => {
        camera.aspect = innerWidth / innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(innerWidth, innerHeight);
        scaleBg();
      });
    </script>
  </body>
</html>
